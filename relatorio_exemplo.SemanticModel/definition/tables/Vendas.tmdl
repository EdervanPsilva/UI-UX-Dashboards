table Vendas
	lineageTag: 75cebe0f-8a9a-41e9-ac4f-93f05c84b9dc

	measure ReceitaTotal =
			
			SUM ( Vendas[ValorTotal] )
		formatString: "R$"#,0.00;-"R$"#,0.00;"R$"#,0.00
		lineageTag: 91530137-b2ce-4c38-b7c9-963961f83e70

		annotation PBI_FormatHint = {"currencyCulture":"es-BR"}

	measure QuantidadeVendida = ```
			
			SUM ( Vendas[Quantidade] )
			
			```
		formatString: #,0
		lineageTag: 55eb66e7-3212-4b36-9876-26fa5785cedc

	measure TicketMedio = ```
			
			DIVIDE (
			    [ReceitaTotal],
			    [QuantidadeVendida],
			    0
			)
			
			```
		formatString: "R$"#,0.00;-"R$"#,0.00;"R$"#,0.00
		lineageTag: 8cf2174a-5c44-4d90-94b2-10171caf9446

		annotation PBI_FormatHint = {"currencyCulture":"es-BR"}

