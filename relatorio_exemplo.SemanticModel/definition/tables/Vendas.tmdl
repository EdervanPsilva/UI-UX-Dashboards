	partition Vendas = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS (
				    GENERATESERIES (1, 500, 1),   -- 500 linhas de vendas simuladas
				    "Data", DATE(2025, RANDBETWEEN(1,12), RANDBETWEEN(1,28)),
				    "ProdutoID", RANDBETWEEN(1,6),
				    "ClienteID", RANDBETWEEN(1,5),
				    "Quantidade", RANDBETWEEN(1,10),
				    "ValorUnitario", RANDBETWEEN(50,500),
				    "ValorTotal", RANDBETWEEN(1,10) * RANDBETWEEN(50,500)
				)
				
				```

	annotation PBI_Id = ea7d6595958842898ebdbfba51632208

